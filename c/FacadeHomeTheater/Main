public class Main{
    public static void main(String[] args){

        TV tv = new TV();
        Projetor projetor = new Projetor();
        Receiver receiver = new Receiver();
        PlayerMidia player = new PlayerMidia();
        SistemaSom som = new SistemaSom();
        LuzAmbiente luz = new LuzAmbiente();

        HomeTheaterFacade homeTheater = new HomeTheaterFacade(tv, projetor, receiver, player, som, luz);

        System.out.println("TESTE DE TODAS AS FUNÇÕES INDIVIDUAIS");

        //TV
        homeTheater.ligarTV();
        homeTheater.desligarTV();

        //Projetor
        homeTheater.ligarProjetor();
        homeTheater.desligarProjetor();

        //Receiver
        homeTheater.ligarReceiver();
        homeTheater.desligarReceiver();

        //Som
        homeTheater.ligarSom();
        homeTheater.ajustarVolumeSom();
        homeTheater.desligarSom();

        //Luz
        homeTheater.ligarLuzAmbiente();
        homeTheater.diminuirLuzAmbiente();

        //Player de Mídia
        homeTheater.ligarPlayer();
        homeTheater.reproduzirFilmePlayer();
        homeTheater.reproduzirMusicaPlayer();
        homeTheater.desligarPlayer();

        System.out.println("TESTE DOS MODOS AUTOMÁTICOS");
        
        homeTheater.assistirFilme();
        homeTheater.ouvirMusica();
        homeTheater.desligarSistema();
    }
}