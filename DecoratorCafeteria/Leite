public class Leite extends AdicionalDecorator{
    public Leite(Bebida bebida){
        super(bebida);
    }

    @Override
    public String getDescricao(){
        return bebidaEnvolvida.getDescricao() + ", Leite";
    }

    @Override
    public double getCusto(){
        return bebidaEnvolvida.getCusto() + 1.50;
    }
}